  "formulaSheets": [
    {
      "subjectId": "algorithms",
      "title": "Algorithms Cheat Sheet",
      "formulas": [
        { "name": "Master Theorem", "formula": "T(n) = aT(n/b) + f(n). Case 1: T(n) = Θ(n^(log_b(a))). Case 2: T(n) = Θ(n^(log_b(a)) * log n). Case 3: T(n) = Θ(f(n)).", "trick": "Think of it as tree depth weight vs. leaf weight." },
        { "name": "Huffman Coding Complexity", "formula": "O(n log n) using Min-Heap.", "trick": "Always extract two minimum values recursively." }
      ]
    },
    {
      "subjectId": "os",
      "title": "OS Process Sync Formulas",
      "formulas": [
        { "name": "Effective Access Time (Paging)", "formula": "EAT = Hit Ratio * (TLB access + Memory access) + Miss Ratio * (TLB access + 2 * Memory access)", "trick": "TLB is checked first. Miss causes double memory lookup (Page table + actual data)." },
        { "name": "Disk Head Movement (SSTF)", "formula": "Sum of absolute differences |current - request| sorted by proximity.", "trick": "Always greedily choose the closest cylinder next. Watch out for starvation!" }
      ]
    }
  ],
